{
  "gateway": {
    "mode": "local",
    "port": 18771,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "REDACTED_GATEWAY_TOKEN"
    },
    "tailscale": {
      "mode": "serve",
      "resetOnExit": true
    },
    "remote": {
      "url": "wss://alienware.tailb5e976.ts.net"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18771",
        "http://127.0.0.1:18771",
        "https://alienware.tailb5e976.ts.net"
      ],
      "allowInsecureAuth": false
    },
    "trustedProxies": [
      "loopback",
      "100.109.60.113",
      "100.69.175.80"
    ]
  },
  "env": {
    "shellEnv": {
      "enabled": true
    },
    "vars": {}
  },
  "agents": {
    "defaults": {
      "workspace": "/home/marku/.openclaw/workspace",
      "maxConcurrent": 3,
      "thinkingDefault": "low",
      "model": {
        "primary": "ollama/gemma4",
        "fallbacks": [
          "ollama/gemma4:latest"
        ]
      }
    },
    "list": [
      {
        "id": "main",
        "model": "ollama/gemma4:latest",
        "skills": [
          "root-router"
        ]
      },
      {
        "id": "operator",
        "name": "Operator",
        "model": "ollama/gemma4:latest",
        "skills": [
          "root-router"
        ],
        "heartbeat": {
          "every": "45m",
          "isolatedSession": true,
          "lightContext": true,
          "prompt": "1. Execute the healthcheck-run-all tool. 2. If 'status' is 'error', immediately initiate the self-healing workflow. 3. If no faults are detected, report HEARTBEAT_OK."
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "api": "openai-completions",
        "apiKey": "OLLAMA_API_KEY",
        "models": [
          {
            "id": "gemma4",
            "name": "gemma4",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 96000,
            "maxTokens": 8192
          },
          {
            "id": "gemma4:latest",
            "name": "gemma4:latest",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 96000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "plugins": {
    "allow": [
      "active-memory",
      "google",
      "loader",
      "lobster",
      "memory-core",
      "ollama",
      "tool-strategy"
    ],
    "entries": {
      "loader": {
        "enabled": true,
        "config": {
          "localPath": "/home/marku/.openclaw/extensions/loader"
        }
      },
      "tool-strategy": {
        "enabled": true
      },
      "active-memory": {
        "enabled": true
      },
      "ollama": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.5.2",
    "lastTouchedAt": "2026-05-04T12:00:00Z"
  }
}
