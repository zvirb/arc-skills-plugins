{
  "compilerOptions": { "types": ["node"], "ignoreDeprecations": "6.0", "noImplicitAny": false, "skipLibCheck": true, "allowJs": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": ["src/**/*"]
}
