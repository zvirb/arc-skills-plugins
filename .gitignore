# OpenClaw Workspace GitIgnore - Comprehensive Standard 2026.5.x

# Runtime Artifacts
*.log
*.out
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.lobster
new_task_id.txt
scratch_log.jsonl

# Audit & Health Logs
mega_audit.log
audit_*.log
MEGA_AUDIT_LOG.md
SKILL_AUDIT_LOG.md
OpenClaw_Audit_Registry.md
EXHAUSTIVE_OMEGA_REPORT.md
OMEGA_FUNCTIONAL_REPORT.md

# Dependencies & Environments
node_modules/
.venv/
venv/
.env
*.env.bak
Secrets/
__pycache__/
*.pyc

# Runtime & Workspace State
.clawhub/
.openclaw/
Archive/
scratch/
agents/
coder/
operator/
researcher/
summarizer/
skills_archive/

# Data & Context Isolation
Memory/*
!Memory/context.md
Logs/*
!Logs/context.md

# IDE & System
.vscode/
.idea/
.DS_Store

# Shell & Scripts
*.bash
*.zsh
*.ps1
*.fish
scripts/
!scripts/run.sh
!scripts/execute-tool.mjs
Scripts/
!Scripts/context.md
!Scripts/*.py
!Scripts/*.sh
!Scripts/*.cjs
